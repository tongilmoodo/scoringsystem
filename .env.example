# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-side only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Google Gemini API key (https://aistudio.google.com/apikey).
# Used for voice scoring (/api/voice) and dynamic UI translation (/api/translate).
# Server-side only. Optional: without it, voice scoring is disabled and the UI
# falls back to built-in English/Swahili/French/Spanish dictionaries.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
